{
  "general": {
    "name": "boss_clam_lite",
    "short": "Stellar Parameters from BOSS Spectra with The CLAM",
    "description": "BOSS-CLAM is a data driven method that maps labels to NMF basis weights to forward model continuum normalized BOSS spectra. This model was training with labels from ASPCAP, BOSS-MINESweeper, wide binaries and a validation set of hot stars. This is the lite version of the VAC includes the inferened stellar parameters from all mwmStar BOSS spectra with snr > 10, a series of flags to clean the dataset, and a subset of meta-data from mwmAllStar.",
    "environments": [
      "MWM_STELLAR_PARAMS"
    ],
    "surveys": [
      {
        "name": "SDSS",
        "long": "Sloan Digital Sky Survey",
        "description": "General SDSS Survey",
        "phase": {
          "name": "Phase-V",
          "id": 5,
          "start": 2020,
          "end": null,
          "active": true
        },
        "id": "sdss",
        "aliases": []
      }
    ],
    "datatype": "H5",
    "filesize": "482 MB",
    "releases": [
      {
        "name": "DR20",
        "description": "SDSS public data release 20",
        "public": true,
        "release_date": "2026-07-30"
      }
    ],
    "naming_convention": "$MWM_STELLAR_PARAMS/boss_clam/boss_clam_lite-[V_VAC].h5",
    "generated_by": "https://github.com/andycasey/clam-boss",
    "design": false,
    "vac": true,
    "recommended_science_product": true,
    "data_level": "3.3.0"
  },
