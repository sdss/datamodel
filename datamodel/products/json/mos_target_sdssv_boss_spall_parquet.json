{
  "general": {
    "name": "mos_target_sdssv_boss_spall_parquet",
    "short": "MOS Target Table: sdssv_boss_spall",
    "description": "The dr20_sdssv_boss_spall table is a database representation of an early version of the SDSS-V BOSS spAll data product.\n\nThe dr20_sdssv_boss_spall table was used within early iterations of FPS target_selection as a way to communicate information about which targets had been observed in SDSS-V plates. This information was used to e.g. de-prioritise targets that were expected to have a good quality spectroscopic measurement before the start of SDSS-V FPS operations.\n\nCaution. The dr20_sdssv_boss_spall table should only be used in order to recreate the target_selection selection function.\n\nColumn descriptions are mainly derived from: <a href=\"https://data.sdss.org/datamodel/files/BOSS_SPECTRO_REDUX/RUN2D/spAll.html\">https://data.sdss.org/datamodel/files/BOSS_SPECTRO_REDUX/RUN2D/spAll.html</a>",
    "environments": [
      "MOS_TARGET"
    ],
    "surveys": [
      {
        "name": "SDSS",
        "long": "Sloan Digital Sky Survey",
        "description": "General SDSS Survey",
        "phase": {
          "name": "Phase-V",
          "id": 5,
          "start": 2020,
          "end": null,
          "active": true
        },
        "id": "sdss",
        "aliases": []
      }
