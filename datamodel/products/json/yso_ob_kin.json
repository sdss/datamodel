  "general": {
    "name": "yso_ob_kin",
    "short": "Catalogue of ~50,000 OB stars studying Milky Way disc kinematics",
    "description": "This is a catalogue of ~50,000 OB stars accompanying the paper \"The large-scale kinematics  of young stars in the Milky Way disc: first results from SDSS-V\"  <a href=\"https://ui.adsabs.harvard.edu/abs/2025A%26A...703A.303Z/abstract\">Zari et al., 2025</a>,  in press). The catalogue is described in detail in Section 2.2. of  <a href=\"https://ui.adsabs.harvard.edu/abs/2025A%26A...703A.303Z/abstract\">Zari et al., 2025</a>.  It contains Galactocentric cartesian coordinates and radial velocities and age estimates  of the sample used in the paper.",
    "environments": [
      "MWM_YSO"
    ],
