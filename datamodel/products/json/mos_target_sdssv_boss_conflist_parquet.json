{
  "general": {
    "name": "mos_target_sdssv_boss_conflist_parquet",
    "short": "MOS Target Table: sdssv_boss_conflist",
    "description": "The dr20_sdssv_boss_conflist table is a database representation of an\nearly version of the SDSS-V BOSS fieldlist data product.\n\nThe dr20_sdssv_boss_conflist table was used within early iterations of FPS target_selection as a way to communicate information about which SDSS-V plates had been observed by the time of target selection. This information was used to e.g. de-prioritise targets that were expected to have a good quality spectroscopic measurement before the start of SDSS-V FPS operations.\n\nCaution. The dr20_sdssv_boss_conflist table should only be used in order to recreate the target_selection selection function.\n\nColumn descriptions are mainly derived from: <a href=\"https://data.sdss.org/datamodel/files/BOSS_SPECTRO_REDUX/RUN2D/platelist.html\">https://data.sdss.org/datamodel/files/BOSS_SPECTRO_REDUX/RUN2D/platelist.html</a>",
    "environments": [
      "MOS_TARGET"
    ],
    "surveys": [
      {
        "name": "SDSS",
        "long": "Sloan Digital Sky Survey",
        "description": "General SDSS Survey",
