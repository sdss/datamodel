DR19:
  in_sdss_access: true
  path_name: allspec
  path_template: $ALLSPEC/{vers}/allspec-{release}-{vers}.fits
  path_kwargs:
  - vers
  - release
  access_string: allspec = $ALLSPEC/{vers}/allspec-{release}-{vers}.fits.gz
DR20:
  in_sdss_access: true
  path_name: allspec
  path_template: $ALLSPEC/{vers}/allspec-{release}-{vers}.{ftype}
  path_kwargs:
  - ftype
  - vers
  - release
  access_string: allspec = $ALLSPEC/{vers}/allspec-{release}-{vers}.fits.gz
