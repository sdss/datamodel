IPL4:
  in_sdss_access: true
  path_name: sdR_S
  path_template: $BOSS_SPECTRO_DATA_S/{mjd}/sdR-{br}{id}-{frame}.fit
  path_kwargs:
  - br
  - frame
  - id
  - mjd
  access_string: sdR_S = $BOSS_SPECTRO_DATA_S/{mjd}/sdR-{br}{id}-{frame}.fit.gz
DR20:
  in_sdss_access: true
  path_name: sdR_S
  path_template: $BOSS_SPECTRO_DATA_S/{mjd}/sdR-{br}{id}-{frame}.fit
  path_kwargs:
  - br
  - frame
  - id
  - mjd
  access_string: sdR_S = $BOSS_SPECTRO_DATA_S/{mjd}/sdR-{br}{id}-{frame}.fit.gz
