DR20:
  in_sdss_access: true
  path_name: lvm_dap
  path_template: $LVM_SPECTRO_ANALYSIS/{drpver}/{tileid}/{mjd}/{expnum:0>8}/dap-{rspid}-{snlevel}-{expnum:0>8}.{daptype}.fits
  path_kwargs:
  - snlevel
  - rspid
  - daptype
  - drpver
  - tileid
  - mjd
  - expnum
  access_string: lvm_dap = $LVM_SPECTRO_ANALYSIS/{drpver}/{dapver}/{tilegrp}/{tileid}/{mjd}/{expnum}/dap-{rspid}-{snlevel}-{expnum}.{daptype}.fits
