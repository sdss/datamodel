DR15:
  in_sdss_access: true
  path_name: mangagalaxyzoo
  path_template: $MANGA_MORPHOLOGY/galaxyzoo/MaNGA_gz-{ver}.fits
  path_kwargs:
  - ver
  access_string: mangagalaxyzoo = $MANGA_MORPHOLOGY/galaxyzoo/MaNGA_gz-{ver}.fits
DR17:
  in_sdss_access: true
  path_name: mangagalaxyzoo
  path_template: $MANGA_MORPHOLOGY/galaxyzoo/MaNGA_{file}-{ver}.fits
  path_kwargs:
  - file
  - ver
  access_string: mangagalaxyzoo = $MANGA_MORPHOLOGY/galaxyzoo/MaNGA_gz-{ver}.fits
