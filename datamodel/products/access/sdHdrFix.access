IPL4:
  in_sdss_access: true
  path_name: sdHdrFix
  path_template: $SDSSCORE_DIR/{obs}/sdHdrfix/sdHdrFix-{mjd}.par
  path_kwargs:
  - mjd
  - obs
  access_string: sdHdrFix = $SDSSCORE_DIR/{obs}/sdHdrfix/sdHdrFix-{mjd}.par
DR20:
  in_sdss_access: true
  path_name: sdHdrFix
  path_template: $SDSSCORE_DIR/{obs}/sdHdrfix/sdHdrFix-{mjd}.par
  path_kwargs:
  - mjd
  - obs
  access_string: sdHdrFix = $SDSSCORE_DIR/{obs}/sdHdrfix/sdHdrFix-{mjd}.par
