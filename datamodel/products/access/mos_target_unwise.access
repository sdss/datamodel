DR19:
  in_sdss_access: true
  path_name: mos_target_unwise
  path_template: $MOS_TARGET/{v_targ}/mos_unwise-{num}.fits
  path_kwargs:
  - num
  - v_targ
  access_string: mos_target_unwise = $MOS_TARGET/{v_targ}/mos_unwise-{num}.fits
DR20:
  in_sdss_access: true
  path_name: mos_target_unwise
  path_template: $MOS_TARGET/{v_targ}/{ftype}/mos_unwise@mos_target_num2|.{ftype}
  path_kwargs:
  - ftype
  - v_targ
  access_string: mos_target_unwise = $MOS_TARGET/{v_targ}/{ftype}/mos_unwise-{num}.{ftype}
