DR19:
  in_sdss_access: true
  path_name: mos_target_hole
  path_template: $MOS_TARGET/{v_targ}/mos_hole.fits
  path_kwargs:
  - v_targ
  access_string: mos_target_hole = $MOS_TARGET/{v_targ}/mos_hole.fits
DR20:
  in_sdss_access: true
  path_name: mos_target_hole
  path_template: $MOS_TARGET/{v_targ}/{ftype}/mos_hole.{ftype}
  path_kwargs:
  - v_targ
  - ftype
  access_string: mos_target_hole = $MOS_TARGET/{v_targ}/{ftype}/mos_hole.{ftype}
