DR20:
  in_sdss_access: true
  path_name: lvm_lv_dap
  path_template: $LVM_SPECTRO_ANALYSIS/{drpver}/{dapver}/@tilegrp|/{tileid}/{mjd}/{expnum:0>8}/LV_dap-{rspid}-{snlevel}-{expnum:0>8}.{daptype}.fits
  path_kwargs:
  - tileid
  - dapver
  - daptype
  - rspid
  - snlevel
  - expnum
  - drpver
  - mjd
  access_string: lvm_lv_dap = $LVM_SPECTRO_ANALYSIS/{drpver}/{dapver}/{tilegrp}/{tileid}/{mjd}/{expnum}/dap-{rspid}-{snlevel}-{expnum}.{daptype}.fits
