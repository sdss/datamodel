IPL4:
  in_sdss_access: true
  path_name: spTraceTab
  path_template: $BOSS_SPECTRO_REDUX/{run2d}/trace/{mjd}/spTraceTab-{br}{id}-{frame}.fits
  path_kwargs:
  - frame
  - br
  - mjd
  - id
  - run2d
  access_string: spTraceTab = $BOSS_SPECTRO_REDUX/{run2d}/trace/{mjd}/spTraceTab-{br}{id}-{frame}.fits
