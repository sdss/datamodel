DR19:
  in_sdss_access: true
  path_name: DR19Q_prop
  path_template: $BHM_QSOPROP/{vers}/DR19Q_prop-{run2d}.fits
  path_kwargs:
  - vers
  - run2d
  access_string: DR19Q_prop = $BHM_QSOPROP/{vers}/DR19Q_prop-{run2d}.fits
DR20:
  in_sdss_access: true
  path_name: DR20Q_prop
  path_template: $BHM_QSOPROP/{vers}/DR20Q_prop-{run2d}.fits
  path_kwargs:
  - run2d
  - vers
  access_string: DR20Q_prop = $BHM_QSOPROP/{vers}/DR20Q_prop-{run2d}.fits
