from ruamel.yaml import YAML
from os import environ
from os.path import join

def update_descriptions(new_node, old_node):
    # If dealing with dictionaries (like the general block, hdus, or column definitions)
    if isinstance(new_node, dict) and isinstance(old_node, dict):
        for key, new_val in new_node.items():
            if key in old_node:
                old_val = old_node[key]
                # Check if this key holds a description we want to replace
                if key in ['short', 'description']:
                    # Look for the autogenerated placeholders from the new datamodel generator
                    if isinstance(new_val, str) and ('replace me' in new_val.lower() or 'label for column' in new_val.lower()):
                        new_node[key] = old_val
                else:
                    # Recursively traverse deeper
                    update_descriptions(new_val, old_val)
                    
    # If dealing with lists (like the FITS header arrays)
    elif isinstance(new_node, list) and isinstance(old_node, list):
        for new_item in new_node:
            # Match list items by 'key' (e.g., header records) or 'name' (e.g., list of columns if structured as list)
            if isinstance(new_item, dict) and 'key' in new_item:
                matching_old = next((item for item in old_node if isinstance(item, dict) and item.get('key') == new_item['key']), None)
                if matching_old:
                    update_descriptions(new_item, matching_old)
            elif isinstance(new_item, dict) and 'name' in new_item:
                matching_old = next((item for item in old_node if isinstance(item, dict) and item.get('name') == new_item['name']), None)
                if matching_old:
                    update_descriptions(new_item, matching_old)

# Setup ruamel.yaml to perfectly preserve your file's structure
yaml = YAML()
yaml.preserve_quotes = True
yaml.width = 4096  # Prevent long lines from wrapping

yaml_dir = join(environ["DATAMODEL_DIR"], 'datamodel', 'products', 'yaml')
new_file = join(yaml_dir, 'eFEDS_SPIDERS_AGN.yaml')
old_file = join(yaml_dir, 'eFEDS_SPIDERS_AGN.2.yaml')
fixed_file = join(yaml_dir, 'eFEDS_SPIDERS_AGN.3.yaml')

print("Loading datamodels...")
with open(new_file, 'r') as f: new_data = yaml.load(f)
with open(old_file, 'r') as f: old_data = yaml.load(f)

print("Merging human descriptions...")
update_descriptions(new_data, old_data)

# Save the updated datamodel
with open(fixed_file, 'w') as f: yaml.dump(new_data, f)
print(f"Success! The merged datamodel has been saved as {fixed_file}.")
