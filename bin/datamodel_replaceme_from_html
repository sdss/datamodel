#!/usr/bin/env python3
import os
import sys
import argparse
import re
import yaml
from bs4 import BeautifulSoup
from datamodels import envvar

def get_html_file(filespec = None):
    html_file = None
    for env, filespecs in envvar.items():
        for fs, content in filespecs['filespec'].items():
            if filespec == fs:
                html_file = content['html_file']
                break
        if html_file: 
            break
    return html_file
    
def main():
    # 1. Set up argument parser
    parser = argparse.ArgumentParser(
        description="Populate 'replace me' fields in a YAML datamodel using its corresponding HTML file."
    )
    parser.add_argument(
        '-f', '--filespec', 
        required=True,
        help="The base name of the data product file (e.g., manga_alfalfa)"
    )
    parser.add_argument(
        '-r', '--release',
        required=True,
        help="The data release key (e.g., DR16, DR17)"
    )
    args = parser.parse_args()
    filespec = args.filespec
    release = args.release
    
    html_file = get_html_file(filespec = filespec)
    if not html_file:
        print("Error: The HTML file is not found in envvar", file=sys.stderr)
        sys.exit(1)

    # 2. Retrieve and validate environment variables
    datamodel_dir = os.environ.get("DATAMODEL_DIR")
    datamodels_dir = os.environ.get("DATAMODELS_DIR")

    if not datamodel_dir:
        print("Error: The 'DATAMODEL_DIR' environment variable is not set.", file=sys.stderr)
        sys.exit(1)
    if not datamodels_dir:
        print("Error: The 'DATAMODELS_DIR' environment variable is not set.", file=sys.stderr)
        sys.exit(1)

    # 3. Construct file paths
    yaml_path = os.path.join(datamodel_dir, "datamodel", "products", "yaml", f"{filespec}.yaml")
    html_path = os.path.join(datamodels_dir, "python", "datamodels", "resources-datamodels", "html", "files", f"{html_file}")
    output_path = os.path.join(datamodel_dir, "datamodel", "products", "yaml", f"{filespec}.1.yaml")

    # 4. Verify input files exist
    if not os.path.exists(yaml_path):
        print(f"Error: YAML file not found at {yaml_path}", file=sys.stderr)
        sys.exit(1)
    if not os.path.exists(html_path):
        print(f"Error: HTML file not found at {html_path}", file=sys.stderr)
        sys.exit(1)

    print(f"Processing '{filespec}' for release '{release}'...")
    print(f"Reading HTML: {html_path}")
    print(f"Reading YAML: {yaml_path}")

    # 5. Parse the HTML file
    with open(html_path, 'r', encoding='utf-8') as f:
        html_content = f.read()
    soup = BeautifulSoup(html_content, 'html.parser')

    # Extract General Info
    gen_desc_dt = soup.find('dt', string=re.compile('General Description', re.I))
    full_description = gen_desc_dt.find_next_sibling('dd').get_text(strip=True) if gen_desc_dt else ""
    full_description_parts = full_description.split('. ') if full_description else [] 
    short_description = full_description_parts[0] + '.' if full_description_parts else ""

    naming_conv_dt = soup.find('dt', string=re.compile('Naming Convention', re.I))
    naming_convention = naming_conv_dt.find_next_sibling('dd').get_text(strip=True) if naming_conv_dt else ""

    written_by_dt = soup.find('dt', string=re.compile('Written by Products|Written by', re.I))
    generated_by = written_by_dt.find_next_sibling('dd').get_text(strip=True) if written_by_dt else ""

    # Locate the Data Columns Table
    columns_table = soup.find('table', class_='columns') or soup.find('table')
    
    columns_by_name = {}
    columns_by_num = {}
    
    if columns_table:
        rows = columns_table.find_all('tr')
        if rows:
            first_row = rows[0]
            header_cells = first_row.find_all(['th', 'td'])
            headers = [cell.get_text(strip=True).lower() for cell in header_cells]
            
            # Default fallbacks (Standard 4-column layout like manga_alfalfa)
            num_idx = -1
            name_idx = 0
            unit_idx = 2
            desc_idx = 3
            
            # Determine if an explicit header layout row exists
            is_header = any(h in headers for h in ['name', 'type', 'unit', 'units', 'description', 'column', 'comment'])
            
            if is_header:
                for idx, h in enumerate(headers):
                    if 'column' in h or 'no.' in h or h == '#':
                        num_idx = idx
                    elif 'name' in h:
                        name_idx = idx
                    elif 'unit' in h:
                        unit_idx = idx
                    elif 'desc' in h or 'comment' in h:
                        desc_idx = idx
                data_rows = rows[1:]  # Skip header row
            else:
                # Direct data fallback for 5-column schemas (like mandala if lacking explicit headers)
                if len(header_cells) >= 5:
                    num_idx = 0
                    name_idx = 1
                    unit_idx = 3
                    desc_idx = 4
                data_rows = rows
                
            # Populate our adaptive dual-lookup dictionaries
            for row in data_rows:
                cols = row.find_all(['td', 'th'])
                if len(cols) > max(name_idx, unit_idx, desc_idx):
                    col_name = cols[name_idx].get_text(strip=True)
                    col_unit = cols[unit_idx].get_text(strip=True)
                    col_desc = cols[desc_idx].get_text(strip=True)
                    
                    col_info_payload = {
                        'unit': col_unit,
                        'description': col_desc,
                        'name': col_name
                    }
                    
                    # Store by name for standard matching
                    columns_by_name[col_name] = col_info_payload
                    
                    # Store by clean column number if available for layout mapping fallbacks
                    if num_idx != -1 and num_idx < len(cols):
                        col_num_raw = cols[num_idx].get_text(strip=True)
                        col_num_digits = ''.join(c for c in col_num_raw if c.isdigit())
                        if col_num_digits:
                            columns_by_num[col_num_digits] = col_info_payload

    # 6. Parse the YAML file
    with open(yaml_path, 'r', encoding='utf-8') as f:
        yaml_data = yaml.safe_load(f)

    # 7. Update General Section metadata fields
    general = yaml_data.get('general', {})
    if 'replace me' in str(general.get('short', '')).lower():
        general['short'] = short_description
    if 'replace me' in str(general.get('description', '')).lower():
        general['description'] = full_description
    if 'replace me' in str(general.get('naming_convention', '')).lower():
        general['naming_convention'] = naming_convention
    if 'replace me' in str(general.get('generated_by', '')).lower():
        general['generated_by'] = generated_by

    # 8. Dynamically Iterate over ALL HDU metadata blocks inside the Release
    try:
        hdus = yaml_data['releases'][release]['hdus']
        
        for hdu_key, hdu_info in hdus.items():
            # Dynamically fetch the matching HDU block description from HTML
            if 'replace me' in str(hdu_info.get('description', '')).lower():
                hdu_div = soup.find('div', id=hdu_key.lower())
                if hdu_div and hdu_div.find('p'):
                    hdu_info['description'] = hdu_div.find('p').get_text(strip=True)
            
            # Map columns inside this specific HDU
            yaml_columns = hdu_info.get('columns', {})
            for col_key, col_info in yaml_columns.items():
                html_col_info = None
                
                # Step A: Direct string matching strategies
                if col_key in columns_by_name:
                    html_col_info = columns_by_name[col_key]
                elif col_info.get('name') in columns_by_name:
                    html_col_info = columns_by_name[col_info.get('name')]
                else:
                    # Case-insensitive resilience match loop
                    for k, info in columns_by_name.items():
                        if k.lower() == col_key.lower() or k.lower() == str(col_info.get('name', '')).lower():
                            html_col_info = info
                            break
                
                # Step B: Fallback Strategy - Column number cross-referencing loop
                if not html_col_info:
                    desc_str = str(col_info.get('description', ''))
                    num_match = re.search(r'column\s+(\d+)', desc_str, re.I)
                    if num_match:
                        col_num = num_match.group(1)
                        if col_num in columns_by_num:
                            html_col_info = columns_by_num[col_num]
                
                # Step C: Write values safely back into the YAML definition map
                if html_col_info:
                    if 'replace me' in str(col_info.get('unit', '')).lower():
                        col_info['unit'] = html_col_info['unit']
                    
                    current_desc = str(col_info.get('description', '')).lower().strip()
                    if 'replace me' in current_desc or 'column' in current_desc:
                        col_info['description'] = html_col_info['description']
                        
    except KeyError as e:
        print(f"Warning: Expected release key structure not found in YAML. Missing: {e}", file=sys.stderr)

    # 9. Save updated data back out to the output target
    with open(output_path, 'w', encoding='utf-8') as f:
        yaml.dump(yaml_data, f, sort_keys=False, default_flow_style=False, allow_unicode=True)
    
    print(f"Success! Generated updated file at: {output_path}")

if __name__ == "__main__":
    main()
